{
  "swagger": "2.0",
  "info": {
    "title": "CyberMate API",
    "version": "1.0.0"
  },
  "tags": [
    {
      "name": "CyberMate"
    }
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/v1/prompts/history": {
      "post": {
        "summary": "CreatePromptHistory",
        "description": "Save prompt history for a Telegram user",
        "operationId": "CyberMate_CreatePromptHistory",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/gotemplateCreatePromptHistoryResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/gotemplateCreatePromptHistoryRequest"
            }
          }
        ],
        "tags": [
          "CyberMate"
        ]
      }
    },
    "/v1/prompts/history/telegram/{telegramId}": {
      "get": {
        "summary": "GetPromptHistoryByTelegramId",
        "description": "Get prompt history by telegram id",
        "operationId": "CyberMate_GetPromptHistoryByTelegramId",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/gotemplateGetPromptHistoryResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "telegramId",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "CyberMate"
        ]
      }
    },
    "/v1/referrals/telegram/{telegramId}": {
      "get": {
        "summary": "GetReferralsByTelegramId",
        "description": "Get referrals by telegram id",
        "operationId": "CyberMate_GetReferralsByTelegramId",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/gotemplateGetReferralsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "telegramId",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "CyberMate"
        ]
      }
    },
    "/v1/register": {
      "post": {
        "summary": "RegisterByTelegram",
        "description": "Register user by Telegram WebApp init data",
        "operationId": "CyberMate_RegisterByTelegram",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/gotemplateRegisterByTelegramResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/gotemplateRegisterByTelegramRequest"
            }
          }
        ],
        "tags": [
          "CyberMate"
        ]
      }
    },
    "/v1/users/telegram/{telegramId}": {
      "get": {
        "summary": "GetUserByTelegramId",
        "description": "Get user profile by telegram id",
        "operationId": "CyberMate_GetUserByTelegramId",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/gotemplateGetUserResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "telegramId",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "CyberMate"
        ]
      }
    },
    "/v1/wallet/telegram/{telegramId}": {
      "get": {
        "summary": "GetWalletByTelegramId",
        "description": "Get wallet summary and recent transactions by telegram id",
        "operationId": "CyberMate_GetWalletByTelegramId",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/gotemplateGetWalletResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "telegramId",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "CyberMate"
        ]
      }
    }
