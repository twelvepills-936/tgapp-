  "definitions": {
    "gotemplateCreatePromptHistoryRequest": {
      "type": "object",
      "properties": {
        "telegramId": {
          "type": "string"
        },
        "prompt": {
          "type": "string"
        },
        "category": {
          "type": "string"
        }
      },
      "required": [
        "telegramId",
        "prompt"
      ]
    },
    "gotemplateCreatePromptHistoryResponse": {
      "type": "object",
      "properties": {
        "item": {
          "$ref": "#/definitions/gotemplatePromptHistoryItem"
        }
      }
    },
    "gotemplateGetPromptHistoryResponse": {
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/gotemplatePromptHistoryItem"
          }
        }
      }
    },
    "gotemplateGetReferralsResponse": {
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/gotemplateReferralItem"
          }
        }
      }
    },
    "gotemplateGetUserResponse": {
      "type": "object",
      "properties": {
        "data": {
          "$ref": "#/definitions/gotemplateUser"
        }
      }
    },
    "gotemplateGetWalletResponse": {
      "type": "object",
      "properties": {
        "wallet": {
          "$ref": "#/definitions/gotemplateWalletData"
        },
        "transactions": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/gotemplateWalletTransactionItem"
          }
        }
      }
    },
    "gotemplatePromptHistoryItem": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "int64"
        },
        "prompt": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        }
      }
    },
    "gotemplateReferralItem": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "int64"
        },
        "telegramId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "username": {
          "type": "string"
        },
        "completedTasksCount": {
          "type": "string",
          "format": "int64"
        },
        "earnings": {
          "type": "string",
          "format": "int64"
        }
      }
    },
    "gotemplateRegisterByTelegramRequest": {
      "type": "object",
      "properties": {
        "initDataRaw": {
          "type": "string"
        },
        "startParam": {
          "type": "string",
          "title": "referrer telegram_id"
        }
      },
      "title": "CyberMate messages",
      "required": [
        "initDataRaw"
      ]
    },
    "gotemplateRegisterByTelegramResponse": {
      "type": "object",
      "properties": {
        "profileId": {
          "type": "string",
          "format": "int64"
        }
      }
    },
    "gotemplateUser": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "int64"
        },
        "name": {
          "type": "string"
        },
        "surname": {
          "type": "string"
        }
      }
    },
    "gotemplateWalletData": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "int64"
        },
        "profileId": {
          "type": "string",
          "format": "int64"
        },
        "balance": {
          "type": "string",
          "format": "int64"
        },
        "totalEarned": {
          "type": "string",
          "format": "int64"
        },
        "balanceAvailable": {
          "type": "string",
          "format": "int64"
        }
      }
    },
    "gotemplateWalletTransactionItem": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "int64"
        },
        "date": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "amount": {
          "type": "string",
          "format": "int64"
        },
        "status": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    }
  }
}
